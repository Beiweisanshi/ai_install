{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zm_tools",
  "version": "0.1.0",
  "identifier": "com.ai-tools.installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "zm_tools",
        "width": 900,
        "height": 700,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost http: https:; frame-src https://challenges.cloudflare.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
